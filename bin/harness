#!/usr/bin/env bash
# Thin wrapper around harness.py so it can be invoked as `harness "task"` from
# any directory. The target repo is the directory from which this wrapper is
# called (harness.py defaults --repo to $PWD).

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -- "$(dirname -- "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE")" && pwd)"
HARNESS_PY="$(cd -- "$SCRIPT_DIR/.." && pwd)/harness.py"

if [[ ! -f "$HARNESS_PY" ]]; then
  echo "harness: cannot find harness.py at $HARNESS_PY" >&2
  exit 1
fi

PYTHON_BIN="${HARNESS_PYTHON:-python3}"

exec "$PYTHON_BIN" "$HARNESS_PY" "$@"
