#!/usr/bin/env bash
# Thin wrapper around the harness CLI so it can be invoked as `harness ...`
# from any directory without installing the package globally. The target
# repo is the directory from which this wrapper is called (the `run`
# subcommand defaults --repo to $PWD).

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -- "$(dirname -- "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"

PYTHON_BIN="${HARNESS_PYTHON:-python3}"

# Make sure `import harness` resolves to the src/ layout without requiring
# `pip install -e .`. Once installed via pip the script entry point is used
# directly and this wrapper is unnecessary.
export PYTHONPATH="${PROJECT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"

exec "$PYTHON_BIN" -m harness "$@"
